{
  "title": "Claude Code 使用状況",
  "uid": "claude-code-telemetry",
  "schemaVersion": 38,
  "version": 4,
  "tags": [
    "claude-code",
    "otel",
    "cost"
  ],
  "description": "Claude Code の OpenTelemetry データに基づくコスト・トークン使用量ダッシュボード",
  "editable": true,
  "style": "dark",
  "refresh": "30s",
  "timezone": "utc",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "1h"
    ],
    "time_options": [
      "1h",
      "6h",
      "24h",
      "7d",
      "30d",
      "90d"
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "累計コスト",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT ROUND(COALESCE(SUM(cost_usd),0), 4) AS value FROM api_requests",
          "format": "table"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "今月のコスト",
      "gridPos": {
        "x": 3,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT ROUND(COALESCE(SUM(cost_usd),0), 4) AS value FROM api_requests WHERE strftime('%Y-%m', event_timestamp) = strftime('%Y-%m','now')",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "今日のコスト",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "orange",
                "value": 3
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT ROUND(COALESCE(SUM(cost_usd),0), 4) AS value FROM api_requests WHERE DATE(event_timestamp) = DATE('now')",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "平均コスト / セッション",
      "gridPos": {
        "x": 9,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT ROUND(COALESCE(SUM(cost_usd) * 1.0 / NULLIF(COUNT(DISTINCT session_id), 0), 0), 4) AS value FROM api_requests",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "平均応答時間",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3000
              },
              {
                "color": "red",
                "value": 8000
              }
            ]
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT ROUND(COALESCE(AVG(duration_ms), 0)) AS value FROM api_requests WHERE duration_ms IS NOT NULL",
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "総セッション数",
      "gridPos": {
        "x": 15,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "super-light-purple"
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(DISTINCT session_id) AS value FROM api_requests",
          "format": "table"
        }
      ]
    },
    {
      "id": 16,
      "type": "stat",
      "title": "キャッシュ効率",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT ROUND(100.0 * SUM(cache_read_tokens) / NULLIF(SUM(input_tokens) + SUM(cache_read_tokens), 0), 1) AS value FROM api_requests",
          "format": "table"
        }
      ]
    },
    {
      "id": 17,
      "type": "stat",
      "title": "キャッシュヒット数",
      "gridPos": {
        "x": 21,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT SUM(cache_read_tokens) AS value FROM api_requests",
          "format": "table"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "日次コスト推移",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 16,
        "h": 9
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%Y-%m-%dT00:00:00Z', event_timestamp) AS time, ROUND(SUM(cost_usd), 6) AS \"コスト\" FROM api_requests WHERE event_timestamp IS NOT NULL GROUP BY DATE(event_timestamp) ORDER BY time",
          "format": "time_series",
          "timeColumns": [
            "time"
          ]
        }
      ]
    },
    {
      "id": 11,
      "type": "piechart",
      "title": "モデル別コスト割合",
      "gridPos": {
        "x": 16,
        "y": 8,
        "w": 8,
        "h": 9
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "pieType": "donut",
        "displayLabels": [
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "values": [
            "value",
            "percent"
          ]
        },
        "tooltip": {
          "mode": "single"
        },
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*opus.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*sonnet.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*haiku.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawQueryText": "SELECT ROUND(SUM(CASE WHEN model='claude-sonnet-4-6' THEN cost_usd ELSE 0 END),4) AS \"claude-sonnet-4-6\", ROUND(SUM(CASE WHEN model='claude-opus-4-5' THEN cost_usd ELSE 0 END),4) AS \"claude-opus-4-5\", ROUND(SUM(CASE WHEN model='claude-sonnet-4-5' THEN cost_usd ELSE 0 END),4) AS \"claude-sonnet-4-5\", ROUND(SUM(CASE WHEN model='claude-opus-4-6' THEN cost_usd ELSE 0 END),4) AS \"claude-opus-4-6\", ROUND(SUM(CASE WHEN model LIKE 'claude-haiku-4-5-%' THEN cost_usd ELSE 0 END),4) AS \"claude-haiku-4-5\", ROUND(SUM(CASE WHEN model NOT IN ('claude-sonnet-4-6','claude-opus-4-5','claude-sonnet-4-5','claude-opus-4-6') AND model NOT LIKE 'claude-haiku-4-5-%' THEN cost_usd ELSE 0 END),4) AS \"other\" FROM api_requests WHERE model IS NOT NULL",
          "format": "table"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "日次トークン使用量",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 16,
        "h": 9
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "hue",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "barAlignment": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "input"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "output"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cache_read"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cache_creation"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%Y-%m-%dT00:00:00Z', event_timestamp) AS time, SUM(input_tokens) AS input, SUM(output_tokens) AS output, SUM(cache_read_tokens) AS cache_read, SUM(cache_creation_tokens) AS cache_creation FROM api_requests WHERE event_timestamp IS NOT NULL GROUP BY DATE(event_timestamp) ORDER BY time",
          "format": "time_series",
          "timeColumns": [
            "time"
          ]
        }
      ]
    },
    {
      "id": 13,
      "type": "bargauge",
      "title": "モデル別 呼び出し回数",
      "gridPos": {
        "x": 16,
        "y": 17,
        "w": 8,
        "h": 9
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*opus.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*sonnet.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*haiku.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(CASE WHEN model='claude-sonnet-4-6' THEN 1 END) AS \"claude-sonnet-4-6\", COUNT(CASE WHEN model='claude-opus-4-5' THEN 1 END) AS \"claude-opus-4-5\", COUNT(CASE WHEN model='claude-sonnet-4-5' THEN 1 END) AS \"claude-sonnet-4-5\", COUNT(CASE WHEN model='claude-opus-4-6' THEN 1 END) AS \"claude-opus-4-6\", COUNT(CASE WHEN model LIKE 'claude-haiku-4-5-%' THEN 1 END) AS \"claude-haiku-4-5\", COUNT(CASE WHEN model NOT IN ('claude-sonnet-4-6','claude-opus-4-5','claude-sonnet-4-5','claude-opus-4-6') AND model NOT LIKE 'claude-haiku-4-5-%' THEN 1 END) AS \"other\" FROM api_requests WHERE model IS NOT NULL",
          "format": "table"
        }
      ]
    },
    {
      "id": 18,
      "type": "bargauge",
      "title": "ツール使用ランキング（全期間）",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 8,
        "h": 9
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {
          "values": true,
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^value$/"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-BlYlRd"
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT json_extract(raw_json, '$.tool_name') AS metric, COUNT(*) AS value FROM session_events WHERE event_name = 'tool_result' AND json_extract(raw_json, '$.tool_name') IS NOT NULL GROUP BY metric ORDER BY value DESC LIMIT 15",
          "format": "table"
        }
      ]
    },
    {
      "id": 14,
      "type": "table",
      "title": "セッション別サマリー (直近20件)",
      "gridPos": {
        "x": 8,
        "y": 26,
        "w": 16,
        "h": 9
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "total_cost_usd"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 4
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-GrYlRd"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "api_calls"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "gradient"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "total_input_tokens"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "total_output_tokens"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "session_id"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 220
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawQueryText": "SELECT session_id, session_start, session_end, api_calls, total_cost_usd, total_input_tokens, total_output_tokens, models_used FROM session_summary ORDER BY session_start DESC LIMIT 20",
          "format": "table"
        }
      ]
    },
    {
      "id": 15,
      "type": "table",
      "title": "直近APIリクエスト",
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "cost_usd"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 6
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-GrYlRd"
                }
              }
            ]
