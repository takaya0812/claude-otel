{
  "title": "リアルタイム アクティビティ モニター",
  "uid": "claude-code-realtime",
  "schemaVersion": 38,
  "version": 3,
  "tags": [
    "claude-code",
    "realtime",
    "monitor"
  ],
  "description": "Claude Code のリアルタイムアクティビティモニター（5秒更新）",
  "editable": true,
  "style": "dark",
  "refresh": "2s",
  "timezone": "utc",
  "time": {
    "from": "now-2h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m"
    ],
    "time_options": [
      "15m",
      "30m",
      "1h",
      "3h",
      "6h",
      "24h"
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "直近2時間 API呼び出し",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(*) AS value FROM api_requests WHERE event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours')",
          "format": "table"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "直近2時間 コスト",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT ROUND(COALESCE(SUM(cost_usd), 0), 4) AS value FROM api_requests WHERE event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours')",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "アクティブセッション",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(DISTINCT session_id) AS value FROM api_requests WHERE event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours')",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "平均応答時間（直近2時間）",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3000
              },
              {
                "color": "red",
                "value": 8000
              }
            ]
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT ROUND(COALESCE(AVG(duration_ms), 0)) AS value FROM api_requests WHERE event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours') AND duration_ms IS NOT NULL",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "直近2時間 ツール実行",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(*) AS value FROM session_events WHERE event_name = 'tool_result' AND event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours')",
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "直近2時間 ユーザープロンプト",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(*) AS value FROM session_events WHERE event_name = 'user_prompt' AND event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours')",
          "format": "table"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "直近2時間 キャッシュ効率",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 3
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT ROUND(100.0 * SUM(cache_read_tokens) / NULLIF(SUM(input_tokens) + SUM(cache_read_tokens), 0), 1) AS value FROM api_requests WHERE event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours')",
          "format": "table"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "API呼び出し数（5分ごと）",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 8,
        "h": 10
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 5
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%Y-%m-%dT%H:', event_timestamp) || printf('%02d', (CAST(strftime('%M', event_timestamp) AS INTEGER) / 5) * 5) || ':00Z' AS time, COUNT(*) AS api_calls FROM api_requests WHERE event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours') GROUP BY strftime('%Y-%m-%dT%H:', event_timestamp) || printf('%02d', (CAST(strftime('%M', event_timestamp) AS INTEGER) / 5) * 5) ORDER BY time ASC",
          "format": "time_series",
          "timeColumns": [
            "time"
          ]
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "コスト推移（5分ごと）",
      "gridPos": {
        "x": 8,
        "y": 7,
        "w": 8,
        "h": 10
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%Y-%m-%dT%H:', event_timestamp) || printf('%02d', (CAST(strftime('%M', event_timestamp) AS INTEGER) / 5) * 5) || ':00Z' AS time, ROUND(SUM(cost_usd), 6) AS cost_usd FROM api_requests WHERE event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours') GROUP BY strftime('%Y-%m-%dT%H:', event_timestamp) || printf('%02d', (CAST(strftime('%M', event_timestamp) AS INTEGER) / 5) * 5) ORDER BY time ASC",
          "format": "time_series",
          "timeColumns": [
            "time"
          ]
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "直近のイベントストリーム",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 16,
        "h": 10
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "sortBy": [
          {
            "displayName": "timestamp",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "event_type"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 160
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "api_request": {
                        "color": "blue",
                        "index": 0
                      },
                      "user_prompt": {
                        "color": "green",
                        "index": 1
                      },
                      "tool_result": {
                        "color": "orange",
                        "index": 2
                      },
                      "tool_decision": {
                        "color": "yellow",
                        "index": 3
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-text"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "timestamp"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 190
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "session_id"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawQueryText": "SELECT event_timestamp AS timestamp, 'api_request' AS event_type, model AS detail, ROUND(cost_usd, 6) AS cost_usd, duration_ms, session_id FROM api_requests WHERE event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours') UNION ALL SELECT event_timestamp AS timestamp, event_name AS event_type, '' AS detail, NULL AS cost_usd, NULL AS duration_ms, session_id FROM session_events WHERE event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours') ORDER BY timestamp DESC LIMIT 50",
          "format": "table"
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "ツール使用ランキング（直近2時間）",
      "gridPos": {
        "x": 16,
        "y": 17,
        "w": 8,
        "h": 10
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "sortBy": [
          {
            "displayName": "calls",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "calls"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              },
              {
                "id": "custom.displayMode",
                "value": "lcd-gauge"
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-BlYlRd"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawQueryText": "SELECT json_extract(raw_json, '$.tool_name') AS tool_name, COUNT(*) AS calls FROM session_events WHERE event_name = 'tool_result' AND event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours') AND json_extract(raw_json, '$.tool_name') IS NOT NULL GROUP BY tool_name ORDER BY calls DESC LIMIT 15",
          "format": "table"
        }
      ]
    },
    {
      "id": 11,
      "type": "table",
      "title": "セッション別集計（直近2時間）",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 6
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "sortBy": [
          {
            "displayName": "total_cost_usd",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "total_cost_usd"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 6
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "avg_duration_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawQueryText": "SELECT session_id, user_email, COUNT(*) AS api_calls, ROUND(SUM(cost_usd), 6) AS total_cost_usd, SUM(input_tokens) AS input_tokens, SUM(output_tokens) AS output_tokens, ROUND(AVG(duration_ms)) AS avg_duration_ms, GROUP_CONCAT(DISTINCT model) AS models, MAX(event_timestamp) AS last_active FROM api_requests WHERE event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours') GROUP BY session_id, user_email ORDER BY total_cost_usd DESC",
          "format": "table"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "直近2時間 トークン",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 3
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "targets": [
        {
          "rawQueryText": "SELECT COALESCE(SUM(input_tokens + output_tokens), 0) AS value FROM api_requests WHERE event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours')",
          "format": "table"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "トークン推移（5分ごと）",
      "gridPos": {
        "x": 16,
        "y": 7,
        "w": 8,
        "h": 10
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "input_tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "output_tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%Y-%m-%dT%H:', event_timestamp) || printf('%02d', (CAST(strftime('%M', event_timestamp) AS INTEGER) / 5) * 5) || ':00Z' AS time, SUM(input_tokens) AS input_tokens, SUM(output_tokens) AS output_tokens FROM api_requests WHERE event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours') GROUP BY strftime('%Y-%m-%dT%H:', event_timestamp) || printf('%02d', (CAST(strftime('%M', event_timestamp) AS INTEGER) / 5) * 5) || ':00Z' ORDER BY time ASC",
          "format": "time_series",
          "timeColumns": [
            "time"
          ]
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "リクエスト別トークン消費",
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 24,
        "h": 10
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "decimals": 0,
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 80,
            "pointSize": 5,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "input_tokens"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "入力"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "output_tokens"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "出力"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cache_read_tokens"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "キャッシュ読取"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "teal"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawQueryText": "SELECT event_timestamp AS time, input_tokens, output_tokens, cache_read_tokens FROM api_requests WHERE event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-2 hours') ORDER BY event_timestamp ASC",
          "format": "time_series",
          "timeColumns": [
            "time"
          ]
        }
      ]
    }
  ]
}