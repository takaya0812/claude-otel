{
  "title": "Claude Code アクティビティ分析",
  "uid": "claude-code-activity",
  "schemaVersion": 38,
  "version": 1,
  "tags": [
    "claude-code",
    "activity",
    "tools"
  ],
  "description": "ツール使用品質・プロンプト・エラー・MCP/スキル/フック統計",
  "editable": true,
  "style": "dark",
  "refresh": "1m",
  "timezone": "utc",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "30s",
      "1m",
      "5m",
      "15m",
      "1h"
    ],
    "time_options": [
      "1h",
      "6h",
      "24h",
      "7d",
      "30d"
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "ツール accept 率",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawQueryText": "SELECT\n  ROUND(\n    100.0 * SUM(CASE WHEN json_extract(raw_json, '$.decision') = 'accept' THEN 1 ELSE 0 END)\n    / NULLIF(COUNT(*), 0),\n    1\n  ) AS value\nFROM session_events\nWHERE event_name = 'tool_decision'\n  AND event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-7 days')",
          "format": "table"
        }
      ]
    },
    {
