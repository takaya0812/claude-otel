        {
          "rawQueryText": "SELECT\n  json_extract(raw_json, '$.tool_name') AS tool_name,\n  ROUND(AVG(CAST(json_extract(raw_json, '$.duration_ms') AS REAL)), 0) AS avg_ms\nFROM session_events\nWHERE event_name = 'tool_result'\n  AND json_extract(raw_json, '$.duration_ms') IS NOT NULL\n  AND event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-7 days')\nGROUP BY json_extract(raw_json, '$.tool_name')\nORDER BY avg_ms DESC\nLIMIT 15",
          "format": "table"
        }
      ]
