    {
      "id": 7,
      "type": "barchart",
      "title": "ツール別 accept/reject 件数",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 9
      },
      "datasource": "Claude Code Telemetry",
      "options": {
        "xField": "tool_name",
        "stacking": "normal",
        "orientation": "auto",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "accept"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "reject"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#F2495C",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawQueryText": "SELECT\n  json_extract(raw_json, '$.tool_name') AS tool_name,\n  SUM(CASE WHEN json_extract(raw_json, '$.decision') = 'accept' THEN 1 ELSE 0 END) AS accept,\n  SUM(CASE WHEN json_extract(raw_json, '$.decision') = 'reject' THEN 1 ELSE 0 END) AS reject\nFROM session_events\nWHERE event_name = 'tool_decision'\n  AND event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-7 days')\nGROUP BY json_extract(raw_json, '$.tool_name')\nORDER BY (accept + reject) DESC\nLIMIT 15",
          "format": "table"
        }
      ]
    },
    {
      "id": 8,
      "type": "barchart",
      "title": "ツール別 平均実行時間",
      "gridPos": {
