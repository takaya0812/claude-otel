{
  "title": "Claude Code アクティビティ分析",
  "uid": "claude-code-activity",
  "schemaVersion": 38,
  "version": 1,
  "tags": [
    "claude-code",
    "activity",
    "tools"
  ],
  "description": "ツール使用品質・プロンプト・エラー・MCP/スキル/フック統計",
  "editable": true,
  "style": "dark",
  "refresh": "1m",
  "timezone": "utc",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "30s",
      "1m",
      "5m",
      "15m",
      "1h"
    ],
    "time_options": [
      "1h",
      "6h",
      "24h",
      "7d",
      "30d"
    ]
  },
  "panels": [
    {
      "id": 9,
      "type": "stat",
      "title": "総プロンプト数",
      "gridPos": { "x": 0, "y": 13, "w": 6, "h": 4 },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value\nFROM session_events\nWHERE event_name = 'user_prompt'\n  AND event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-7 days')",
          "format": "table"
        }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "平均プロンプト長",
      "gridPos": { "x": 6, "y": 13, "w": 6, "h": 4 },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT\n  ROUND(AVG(CAST(json_extract(raw_json, '$.prompt_length') AS INTEGER)), 0) AS value\nFROM session_events\nWHERE event_name = 'user_prompt'\n  AND json_extract(raw_json, '$.prompt_length') IS NOT NULL\n  AND event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-7 days')",
          "format": "table"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "日次プロンプト数推移",
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 8 },
      "datasource": "Claude Code Telemetry",
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT\n  DATE(event_timestamp) || 'T00:00:00Z' AS time,\n  COUNT(*) AS prompt_count\nFROM session_events\nWHERE event_name = 'user_prompt'\n  AND event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-7 days')\nGROUP BY DATE(event_timestamp)\nORDER BY time ASC",
          "format": "time_series",
          "timeColumns": ["time"]
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "API エラー数",
      "gridPos": { "x": 0, "y": 25, "w": 6, "h": 4 },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value\nFROM session_events\nWHERE event_name = 'api_error'\n  AND event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-7 days')",
          "format": "table"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "内部エラー数",
      "gridPos": { "x": 6, "y": 25, "w": 6, "h": 4 },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value\nFROM session_events\nWHERE event_name = 'internal_error'\n  AND event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-7 days')",
          "format": "table"
        }
      ]
    },
    {
      "id": 14,
      "type": "stat",
      "title": "認証エラー数",
      "gridPos": { "x": 12, "y": 25, "w": 6, "h": 4 },
      "datasource": "Claude Code Telemetry",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value\nFROM session_events\nWHERE event_name = 'auth'\n  AND json_extract(raw_json, '$.success') = 'false'\n  AND event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-7 days')",
          "format": "table"
        }
      ]
    },
    {
      "id": 15,
      "type": "table",
      "title": "API エラー詳細一覧",
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 9 },
      "datasource": "Claude Code Telemetry",
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT\n  event_timestamp AS timestamp,\n  json_extract(raw_json, '$.model') AS model,\n  json_extract(raw_json, '$.status_code') AS status_code,\n  CAST(json_extract(raw_json, '$.attempt') AS INTEGER) AS attempt,\n  CAST(json_extract(raw_json, '$.duration_ms') AS INTEGER) AS duration_ms,\n  SUBSTR(json_extract(raw_json, '$.error'), 1, 120) AS error_message\nFROM session_events\nWHERE event_name = 'api_error'\n  AND event_timestamp >= strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-7 days')\nORDER BY event_timestamp DESC\nLIMIT 50",
          "format": "table"
        }
      ]
    }
  ]
}
