              <mxPoint x="80" y="760" />
              <mxPoint x="80" y="580" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 10. start-monitoring.sh → ingest.py (exec) -->
        <mxCell id="arr10" value="&lt;b&gt;exec python3 --watch&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#4caf50;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;endArrow=open;" edge="1" source="script" target="ingest" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

